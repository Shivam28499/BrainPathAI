# Server
PORT=5000

# Frontend URL for CORS (comma-separate multiple, no trailing slash)
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app
# Both: http://localhost:3000,https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=brainpath
DB_DIALECT=mysql
# Set to "true" for managed MySQL providers like Railway/Aiven/PlanetScale
DB_SSL=false

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Groq
GROQ_API_KEY=gsk_xxx_your_groq_key

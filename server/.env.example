# Server
PORT=5000

# Frontend URL for CORS (comma-separate multiple, no trailing slash)
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app
# Both: http://localhost:3000,https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# Database
# Dialect can be "mysql" or "postgres" — models are portable across both
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=brainpath
# Set to "true" for managed DB providers like Render Postgres / Neon / Railway
DB_SSL=true

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Groq
GROQ_API_KEY=gsk_xxx_your_groq_key
